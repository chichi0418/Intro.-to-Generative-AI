# ── LLM Provider API Keys ─────────────────────────────────────────────────────
# Fill in whichever providers you want to use.
# Keys left blank fall back to the server key (if set); unused providers won't error.

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...          # Free tier available — Gemini 3 Flash Preview
X_API_KEY=xai-...               # xAI / Grok

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Server-key Quota (rate limiting for shared server keys) ───────────────────
SERVER_KEY_FREE_LIMIT=20        # max free requests per window per client
SERVER_KEY_FREE_WINDOW_MS=86400000  # window size in ms (default: 24 h)

# ── Admin panel ───────────────────────────────────────────────────────────────
# Set any secret token. Enter it in Settings → Admin Usage to view/reset quotas.
ADMIN_API_TOKEN=your-secret-admin-token

# ── Supabase Postgres ─────────────────────────────────────────────────────────
# Required for: persistent quota tracking + long-term memory.
# Without these, quota resets on server restart and memory features are disabled.
#
# Prefer SUPABASE_POOLER_URL (connection pooling) to avoid IPv6 issues on Render.
SUPABASE_POOLER_URL=postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres

# ── Tool Use ──────────────────────────────────────────────────────────────────
# Optional: enables the web_search tool. Get a free key at https://tavily.com
# Without this key, web_search returns an explanatory error instead of results.
# The calculator and get_weather tools work without any key.
TAVILY_API_KEY=tvly-...

# ── MCP (Model Context Protocol) ─────────────────────────────────────────────
# Optional: JSON array of external MCP server configs to mount as tools.
# Each entry: { "command": "npx", "args": ["-y", "@some/mcp-server"], "env": {} }
# Leave empty array if not using MCP.
MCP_SERVERS=[{"command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/tmp"]}]
